<!-- Custom Wazuh rules — place in /var/ossec/etc/rules/local_rules.xml -->
<group name="local,soc-lab">

  <!-- SSH brute force: >10 failed logins in 60s -->
  <rule id="100001" level="12" frequency="10" timeframe="60">
    <if_matched_sid>5760</if_matched_sid>
    <description>SSH brute force attempt — multiple failed logins</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,pci_dss_10.2.4,</group>
  </rule>

  <!-- Nmap scan detection via high connection frequency -->
  <rule id="100002" level="10" frequency="20" timeframe="10">
    <if_matched_sid>40101</if_matched_sid>
    <description>Possible port scan detected — high connection rate</description>
    <mitre>
      <id>T1595.001</id>
    </mitre>
    <group>recon,</group>
  </rule>

  <!-- Suspicious PowerShell execution -->
  <rule id="100003" level="14">
    <if_sid>92200</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(iex|invoke-expression|downloadstring|bypass|hidden|encodedcommand)</field>
    <description>Suspicious PowerShell execution detected</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>attack,</group>
  </rule>

  <!-- New scheduled task creation -->
  <rule id="100004" level="11">
    <if_sid>92654</if_sid>
    <description>Scheduled task created — possible persistence</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
    <group>persistence,</group>
  </rule>

  <!-- Outbound connection to non-standard port — possible C2 -->
  <rule id="100005" level="12">
    <if_sid>40111</if_sid>
    <field name="data.dstport" type="pcre2">^(4444|4445|8888|9999|1337|31337)$</field>
    <description>Outbound connection to suspicious port — possible C2 beacon</description>
    <mitre>
      <id>T1071.001</id>
    </mitre>
    <group>c2,</group>
  </rule>

</group>
